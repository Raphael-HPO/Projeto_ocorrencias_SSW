// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model ocorrencia {
  key     String @id @unique @db.VarChar(100)
  retorno String @default("aguardando") @db.VarChar(100)
}
